# --- secrets & env (FM-07) ---
.env
.env.*
!.env.example
*.key
secrets/

# --- python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.python-version

# --- test / lint caches ---
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
