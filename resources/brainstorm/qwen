│   │   ├── __init__.py
│   │   ├── agent_supervisor.py
│   │   └── orchestrator.py
│   ├── memory/
│   │   ├── __init__.py
│   │   ├── vector_store.py
│   │   ├── sql_saver.py
│   │   └── audit_chain.py
│   ├── tools/
│   │   ├── __init__.py
