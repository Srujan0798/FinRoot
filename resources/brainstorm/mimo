"""Conversation Memory Manager — short-term and long-term memory integration."""

from langchain.memory import ConversationBufferWindowMemory, ConversationSummaryMemory
from langchain_community.vectorstores import Chroma
from langchain_openai import OpenAIEmbeddings
from langchain_core.messages import HumanMessage, AIMessage

from config.settings import settings


class ConversationMemoryManager:
    """Manages both short-term (window) and long-term (vector) conversation memory."""

    def __init__(self):
        # Short-term: last 20 exchanges
        self.buffer_memory = ConversationBufferWindowMemory(
            k=20,
            return_messages=True,
            memory_key="chat_history",
        )

        # Long-term: vector store for retrieval
        try:
            self.embeddings = OpenAIEmbeddings(openai_api_key=settings.openai_api_key)
            self.vectorstore = Chroma(
                persist_directory=settings.chroma_persist_dir,
                embedding_function=self.embeddings,
            )
            self.long_term_available = True
        except Exception:
            self.long_term_available = False

    def add_exchange(self, user_input: str, assistant_response: str):
        """Add a conversation exchange to both memories."""
        self.buffer_memory.chat_memory.add_user_message(user_input)
        self.buffer_memory.chat_memory.add_ai_message(assistant_response)

        if self.long_term_available:
            self.vectorstore.add_texts(
                texts=[f"User: {user_input}\nAssistant: {assistant_response}"],
                metadatas=[{"type": "conversation"}],
            )

    def get_context(self) -> list[dict]:
        """Get current conversation context from short-term memory."""
        messages = self.buffer_memory.chat_memory.messages
        return [
            {"role": "user" if isinstance(m, HumanMessage) else "assistant", "content": m.content}
            for m in messages
        ]

    def retrieve_relevant(self, query: str, k: int = 3) -> list[str]:
        """Retrieve relevant past conversations from long-term memory."""
        if not self.long_term_available:
            return []
        results = self.vectorstore.similarity_search(query, k=k)
        return [doc.page_content for doc in results]
