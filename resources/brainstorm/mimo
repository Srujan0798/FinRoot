```python
"""
Reasoning Quality Evaluator — automated + rubric-based evaluation.
This is the core component that proves the 35% reasoning quality weight.
"""

import json
import logging
from typing import Optional
from dataclasses import dataclass

from langchain_core.prompts import ChatPromptTemplate
from langchain_core.output_parsers import JsonOutputParser

from config.settings import settings

logger = logging.getLogger(__name__)


@dataclass
class EvaluationResult:
    """Result of evaluating a single question."""
    question_id: str
    domain: str
    correctness_score: float        # 0-10
    risk_awareness_score: float     # 0-10
    actionability_score: float      # 0-10
    explainability_score: float     # 0-10
    overall_score: float            # weighted average
    detailed_feedback: dict
    agent_response: str
    critique_result: dict


class ReasoningQualityEvaluator:
    """
    Evaluates financial reasoning quality across multiple dimensions.
    
    Uses both automated metrics and LLM-based rubric evaluation.
    """

    DIMENSIONS = {
        "correctness": {"weight": 0.30, "description": "Factual accuracy and data grounding"},
        "risk_awareness": {"weight": 0.30, "description": "Identification and quantification of risks"},
        "actionability": {"weight": 0.20, "description": "Specificity and implementability of recommendations"},
        "explainability": {"weight": 0.20, "description": "Clarity of reasoning chain and justification"},
    }

    def __init__(self):
        self.llm = settings.get_llm()
        self.evaluation_chain = self._build_evaluation_chain()
        self.results: list[EvaluationResult] = []

    def _build_evaluation_chain(self):
        """Build the LLM-based evaluation chain."""
        prompt = ChatPromptTemplate.from_messages([
            ("system", """You are an expert financial reasoning evaluator. 
Score the following AI-generated financial analysis on each dimension.

Scoring guide (0-10):
- 0-2: Poor — incorrect, missing, or misleading
- 3-4: Below Average — partially correct but significant gaps
- 5-6: Average — correct basics but lacks depth or nuance
- 7-8: Good — thorough, accurate, well-reasoned
- 9-10: Excellent — comprehensive, nuanced, insightful, actionable

For each dimension, provide a score and specific justification.

Respond in JSON:
{{
  "correctness": {{"score": 0-10, "justification": "..."}},
  "risk_awareness": {{"score": 0-10, "justification": "..."}},
  "actionability": {{"score": 0-10, "justification": "..."}},
  "explainability": {{"score": 0-10, "justification": "..."}}
}}"""),
            ("human", """Question: {question}

Expected reasoning elements:
{expected_elements}

Scoring rubric:
{scoring_rubric}

Agent's response:
{agent_response}

Critique result:
{critique_result}

Evaluate rigorously. Penalize hallucinated data, missing risks, and vague recommendations."""),
        ])

        return prompt | self.llm | JsonOutputParser()

    def evaluate_single(
        self,
        question_id: str,
        domain: str,
        question: str,
        expected_elements: list[str],
        scoring_rubric: dict,
        agent_response: str,
        critique_result: dict,
    ) -> EvaluationResult:
        """Evaluate a single agent response."""
        try:
            scores = self.evaluation_chain.invoke({
                "question": question,
                "expected_elements": json.dumps(expected_elements, indent=2),
                "scoring_rubric": json.dumps(scoring_rubric, indent=2),
                "agent_response": agent_response,
                "critique_result": json.dumps(critique_result, indent=2),
            })
        except Exception as e:
            logger.error(f"Evaluation chain failed: {e}")
            scores = {
                "correctness": {"score": 0, "justification": f"Evaluation failed: {e}"},
                "risk_awareness": {"score": 0, "justification": "N/A"},
                "actionability": {"score": 0, "justification": "N/A"},
                "explainability": {"score": 0, "justification": "N/A"},
            }

        # Extract scores
        correctness = scores.get("correctness", {}).get("score", 0)
        risk_awareness = scores.get("risk_awareness", {}).get("score", 0)
        actionability = scores.get("actionability", {}).get("score", 0)
        explainability = scores.get("explainability", {}).get("score", 0)

        # Weighted overall score
        overall = (
            correctness * self.DIMENSIONS["correctness"]["weight"]
            + risk_awareness * self.DIMENSIONS["risk_awareness"]["weight"]
            + actionability * self.DIMENSIONS["actionability"]["weight"]
            + explainability * self.DIMENSIONS["explainability"]["weight"]
        )

        result = EvaluationResult(
            question_id=question_id,
            domain=domain,
            correctness_score=correctness,
            risk_awareness_score=risk_awareness,
            actionability_score=actionability,
            explainability_score=explainability,
            overall_score=overall,
            detailed_feedback=scores,
            agent_response=agent_response,
            critique_result=critique_result,
        )

        self.results.append(result)
        return result

    def get_aggregate_report(self) -> dict:
        """Generate aggregate evaluation report."""
        if not self.results:
            return {"error": "No evaluation results available"}

        by_domain = {}
        for r in self.results:
            if r.domain not in by_domain:
                by_domain[r.domain] = []
            by_domain[r.domain].append(r)

        report = {
            "total_questions": len(self.results),
            "overall_average": sum(r.overall_score for r in self.results) / len(self.results),
            "dimension_averages": {
                dim: sum(getattr(r, f"{dim}_score") for r in self.results) / len(self.results)
                for dim in self.DIMENSIONS
            },
            "by_domain": {
                domain: {
                    "count": len(results),
                    "average_score": sum(r.overall_score for r in results) / len(results),
                }
                for domain, results in by_domain.items()
            },
            "individual_results": [
                {
                    "id": r.question_id,
                    "domain": r.domain,
                    "overall": r.overall_score,
                    "correctness": r.correctness_score,
                    "risk_awareness": r.risk_awareness_score,
                    "actionability": r.actionability_score,
                    "explainability": r.explainability_score,
                }
                for r in self.results
            ],
        }

        return report
