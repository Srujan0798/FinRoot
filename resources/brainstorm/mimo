"""Risk Calculation Tools — quantitative risk metrics."""

import numpy as np
import yfinance as yf
from langchain_core.tools import tool


@tool
def calculate_portfolio_risk(symbols_str: str, weights_str: str, period: str = "1y") -> str:
    """Calculate portfolio risk metrics including VaR, Sharpe ratio, and max drawdown.
    
    Args:
        symbols_str: Comma-separated stock symbols (e.g., 'AAPL,MSFT,GOOGL')
        weights_str: Comma-separated portfolio weights (e.g., '0.4,0.3,0.3')
        period: Historical period for calculation
    
    Returns:
        Portfolio risk metrics: annualized return, volatility, Sharpe ratio, VaR, max drawdown.
    """
    try:
        symbols = [s.strip() for s in symbols_str.split(",")]
        weights = np.array([float(w.strip()) for w in weights_str.split(",")])

        if len(symbols) != len(weights):
            return "Error: Number of symbols must match number of weights."

        if abs(weights.sum() - 1.0) > 0.01:
            return f"Error: Weights must sum to 1.0 (currently {weights.sum():.4f})."

        # Fetch historical data
        data = yf.download(symbols, period=period, progress=False)["Close"]
        if data.empty:
            return "Error: Could not retrieve historical data."

        # Calculate daily returns
        returns = data.pct_change().dropna()
        portfolio_returns = returns.dot(weights)

        # Risk metrics
        annual_return = portfolio_returns.mean() * 252
        annual_vol = portfolio_returns.std() * np.sqrt(252)
        sharpe_ratio = annual_return / annual_vol if annual_vol > 0 else 0
        var_95 = np.percentile(portfolio_returns, 5) * np.sqrt(252)
        var_99 = np.percentile(portfolio_returns, 1) * np.sqrt(252)

        # Max drawdown
        cumulative = (1 + portfolio_returns).cumprod()
        peak = cumulative.expanding().max()
        drawdown = (cumulative - peak) / peak
        max_drawdown = drawdown.min()

        # Individual asset metrics
        individual_vol = returns.std() * np.sqrt(252)
        correlation_matrix = returns.corr()

        result = (
            f"Portfolio Risk Analysis ({period}):\n\n"
            f"Assets: {symbols}\n"
            f"Weights: {weights.tolist()}\n\n"
            f"METRICS:\n"
            f"  Annualized Return: {annual_return * 100:.2f}%\n"
            f"  Annualized Volatility: {annual_vol * 100:.2f}%\n"
            f"  Sharpe Ratio: {sharpe_ratio:.3f}\n"
            f"  95% VaR (annual): {var_95 * 100:.2f}%\n"
            f"  99% VaR (annual): {var_99 * 100:.2f}%\n"
            f"  Maximum Drawdown: {max_drawdown * 100:.2f}%\n\n"
            f"INDIVIDUAL ASSET VOLATILITY:\n"
        )

        for sym, vol in zip(symbols, individual_vol):
            result += f"  {sym}: {vol * 100:.2f}%\n"

        result += f"\nCORRELATION MATRIX:\n{correlation_matrix.to_string()}\n"

        return result

    except Exception as e:
        return f"Error calculating portfolio risk: {str(e)}"


@tool
def calculate_var(returns_data: str, confidence: float = 0.95) -> str:
    """Calculate Value at Risk for a given set of returns.
    
    Args:
        returns_data: Comma-separated daily returns (e.g., '0.01,-0.02,0.005,...')
        confidence: Confidence level (0.90, 0.95, or 0.99)
    
    Returns:
        Value at Risk at the specified confidence level.
    """
    try:
        returns = np.array([float(r.strip()) for r in returns_data.split(",")])
        var = np.percentile(returns, (1 - confidence) * 100)
        return (
            f"Value at Risk ({confidence*100:.0f}% confidence):\n"
            f"  Daily VaR: {var * 100:.4f}%\n"
            f"  Weekly VaR: {var * np.sqrt(5) * 100:.4f}%\n"
            f"  Monthly VaR: {var * np.sqrt(21) * 100:.4f}%\n"
            f"  Annual VaR: {var * np.sqrt(252) * 100:.4f}%\n"
        )
    except Exception as e:
        return f"Error calculating VaR: {str(e)}"


def get_risk_tools():
    """Return all risk calculation tools."""
    return [calculate_portfolio_risk, calculate_var]
