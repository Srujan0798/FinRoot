**agents/orchestrator.py**

```python
"""
FinRoot Reasoning Orchestrator
Implements a Plan-and-Execute pattern with self-critique verification.
"""

import json
import logging
from typing import Any
from dataclasses import dataclass, field

from langchain_core.messages import HumanMessage, SystemMessage
from langchain_core.output_parsers import JsonOutputParser
from langchain_core.prompts import ChatPromptTemplate
from langchain_core.runnables import RunnablePassthrough

from config.settings import settings
from config.prompts import ORCHESTRATOR_SYSTEM_PROMPT
from agents.market_agent import create_market_agent
from agents.risk_agent import create_risk_agent
from agents.tax_agent import create_tax_agent
from agents.portfolio_agent import create_portfolio_agent
from agents.news_agent import create_news_agent
from agents.critique_agent import create_critique_chain
from memory.conversation_memory import ConversationMemoryManager
from memory.user_profile_memory import UserProfileMemory
from memory.audit_trail import AuditTrail

logger = logging.getLogger(__name__)


@dataclass
class PlanStep:
    """A single step in the execution plan."""
    step_id: int
    agent_name: str
    task_description: str
    expected_output_format: str
    status: str = "pending"
    result: dict = field(default_factory=dict)


@dataclass
class ExecutionPlan:
    """Complete execution plan for a financial query."""
    intent: str
    steps: list[PlanStep]
    raw_plan: str = ""


@dataclass
class FinalRecommendation:
    """Structured final recommendation."""
    summary: str
    detailed_analysis: str
    risks: list[str]
    action_items: list[str]
    confidence_level: str  # 'high', 'medium', 'low'
    reasoning_trace: list[dict]
    critique_result: dict
    disclaimer: str


class FinRootOrchestrator:
    """
    Main orchestrator implementing Plan-and-Execute architecture.
    Coordinates specialized sub-agents and enforces reasoning quality.
    """

    def __init__(self):
        self.llm = settings.get_llm()
        self.conversation_memory = ConversationMemoryManager()
        self.user_profile = UserProfileMemory()
        self.audit_trail = AuditTrail()

        # Initialize sub-agents
        self.agents = {
            "market_analyst": create_market_agent(self.llm),
            "risk_assessor": create_risk_agent(self.llm),
            "tax_planner": create_tax_agent(self.llm),
            "portfolio_optimizer": create_portfolio_agent(self.llm),
            "news_interpreter": create_news_agent(self.llm),
        }

        self.critique_chain = create_critique_chain(self.llm)

        # Intent classifier chain
        self.intent_classifier = self._build_intent_classifier()
        # Plan generator chain
        self.plan_generator = self._build_plan_generator()

    def _build_intent_classifier(self):
        """Build the intent classification chain."""
        prompt = ChatPromptTemplate.from_messages([
            ("system", """Classify the user's financial query into one of these intents:
- portfolio_advice: Questions about portfolio allocation, rebalancing, holdings
- risk_analysis: Questions about risk, volatility, downside protection
- tax_query: Questions about tax implications, optimization, compliance
- news_impact: Questions about how news affects markets/portfolios
- general_finance: General financial questions

Respond with JSON: {{"intent": "<intent>", "reasoning": "<why>"}}"""),
            ("human", "{query}")
        ])
        return prompt | self.llm | JsonOutputParser()

    def _build_plan_generator(self):
        """Build the planning chain."""
        prompt = ChatPromptTemplate.from_messages([
            ("system", ORCHESTRATOR_SYSTEM_PROMPT + """

Available agents: market_analyst, risk_assessor, tax_planner, portfolio_optimizer, news_interpreter.

User financial profile:
{user_profile}

Respond with JSON:
{{"intent": "<intent>", "steps": [
  {{"step_id": 1, "agent_name": "<agent>", "task_description": "<specific task>", 
    "expected_output_format": "<format>"}}
]}}"""),
            ("human", "{query}")
        ])
        return prompt | self.llm | JsonOutputParser()

    def run(self, user_query: str) -> FinalRecommendation:
        """
        Execute the full reasoning pipeline for a user query.

        Steps:
        1. Load context (user profile, conversation history)
        2. Classify intent
        3. Generate execution plan
        4. Execute plan steps sequentially
        5. Synthesize results
        6. Self-critique
        7. Generate final recommendation
        8. Log everything to audit trail
        """
        reasoning_trace = []
        session_id = self.audit_trail.new_session(user_query)

        # Step 1: Load context
        user_profile_data = self.user_profile.get_profile()
        conversation_context = self.conversation_memory.get_context()

        reasoning_trace.append({
            "step": "context_assembly",
            "user_profile": user_profile_data,
            "conversation_length": len(conversation_context),
        })

        # Step 2: Generate execution plan
        try:
            plan_raw = self.plan_generator.invoke({
                "query": user_query,
                "user_profile": json.dumps(user_profile_data, indent=2),
            })
        except Exception as e:
            logger.error(f"Plan generation failed: {e}")
            plan_raw = self._fallback_plan(user_query)

        plan = self._parse_plan(plan_raw)

        reasoning_trace.append({
            "step": "plan_generation",
            "intent": plan.intent,
            "num_steps": len(plan.steps),
            "plan": plan_raw,
        })

        self.audit_trail.log_step(session_id, "plan", plan_raw)

        # Step 4: Execute plan steps
        step_results = []
        for step in plan.steps:
            logger.info(f"Executing step {step.step_id}: {step.agent_name}")

            agent = self.agents.get(step.agent_name)
            if agent is None:
                logger.warning(f"Unknown agent: {step.agent_name}, skipping")
                step.status = "skipped"
                continue

            try:
                result = agent.invoke({
                    "input": step.task_description,
                    "user_profile": json.dumps(user_profile_data),
                    "previous_results": json.dumps(step_results),
                })
                step.result = result
                step.status = "completed"
                step_results.append({
                    "step_id": step.step_id,
                    "agent": step.agent_name,
                    "result": result,
                })
            except Exception as e:
                logger.error(f"Step {step.step_id} failed: {e}")
                step.status = "failed"
                step.result = {"error": str(e)}
                step_results.append({
                    "step_id": step.step_id,
                    "agent": step.agent_name,
                    "error": str(e),
                })

            self.audit_trail.log_step(session_id, f"step_{step.step_id}", {
                "agent": step.agent_name,
                "status": step.status,
                "result": step.result,
            })

        reasoning_trace.append({
            "step": "execution",
            "results": step_results,
        })

        # Step 5: Synthesize
        synthesis = self._synthesize_results(user_query, step_results, user_profile_data)

        reasoning_trace.append({
            "step": "synthesis",
            "output": synthesis,
        })

        # Step 6: Self-critique
        critique_result = self.critique_chain.invoke({
            "query": user_query,
            "analysis": synthesis,
            "user_profile": json.dumps(user_profile_data),
            "reasoning_trace": json.dumps(reasoning_trace),
        })

        reasoning_trace.append({
            "step": "critique",
            "result": critique_result,
        })

        self.audit_trail.log_step(session_id, "critique", critique_result)

        # Step 7: Generate final recommendation
        recommendation = self._build_recommendation(
            user_query, synthesis, critique_result, reasoning_trace
        )

        # Step 8: Update memory
        self.conversation_memory.add_exchange(user_query, recommendation.summary)
        self.audit_trail.log_step(session_id, "final_recommendation", {
            "summary": recommendation.summary,
            "confidence": recommendation.confidence_level,
            "risk_count": len(recommendation.risks),
        })

        return recommendation

    def _parse_plan(self, raw_plan: dict) -> ExecutionPlan:
        """Parse the raw plan output into an ExecutionPlan."""
        steps = []
        for i, step_data in enumerate(raw_plan.get("steps", []), 1):
            steps.append(PlanStep(
                step_id=step_data.get("step_id", i),
                agent_name=step_data.get("agent_name", "market_analyst"),
                task_description=step_data.get("task_description", ""),
                expected_output_format=step_data.get("expected_output_format", "text"),
            ))
        return ExecutionPlan(
            intent=raw_plan.get("intent", "general_finance"),
            steps=steps,
            raw_plan=str(raw_plan),
        )

    def _fallback_plan(self, query: str) -> dict:
        """Generate a simple fallback plan if planning fails."""
        return {
            "intent": "general_finance",
            "steps": [
                {
                    "step_id": 1,
                    "agent_name": "market_analyst",
                    "task_description": query,
                    "expected_output_format": "analysis text",
                }
            ],
        }

    def _synthesize_results(
        self, query: str, step_results: list, user_profile: dict
    ) -> str:
        """Synthesize all step results into coherent analysis."""
        synthesis_prompt = ChatPromptTemplate.from_messages([
            ("system", """You are synthesizing results from multiple financial analysis 
agents into a coherent, well-structured analysis.

Rules:
- Integrate findings from all agents into a unified narrative.
- Resolve any contradictions between agent outputs explicitly.
- Maintain all risk flags and caveats.
- Structure: Key Findings → Analysis → Risks → Implications."""),
            ("human", """Original query: {query}

User profile: {user_profile}

Agent results:
{agent_results}

Synthesize into a comprehensive analysis."""),
        ])

        chain = synthesis_prompt | self.llm
        result = chain.invoke({
            "query": query,
            "user_profile": json.dumps(user_profile, indent=2),
            "agent_results": json.dumps(step_results, indent=2, default=str),
        })
        return result.content

    def _build_recommendation(
        self, query: str, analysis: str, critique: dict, trace: list
    ) -> FinalRecommendation:
        """Build the final structured recommendation."""
        # Check critique verdict
        critique_text = str(critique)
        passed = "APPROVE" in critique_text.upper()

        if not passed:
            # If critique flags issues, note them in risks
            additional_risk = f"CRITIQUE FLAG: The analysis was flagged for revision. See critique details."
            risks = [additional_risk]
        else:
            risks = []

        # Extract risks from analysis (simple heuristic + LLM extraction)
        risk_extraction_prompt = ChatPromptTemplate.from_messages([
            ("system", """Extract a list of specific financial risks mentioned in this analysis.
Return as a JSON list of strings. If no risks are explicitly mentioned, return ["No specific risks identified — review recommended"]"""),
            ("human", "{analysis}"),
        ])

        risk_chain = risk_extraction_prompt | self.llm | JsonOutputParser()
        try:
            extracted_risks = risk_chain.invoke({"analysis": analysis})
            if isinstance(extracted_risks, list):
                risks.extend(extracted_risks)
            elif isinstance(extracted_risks, dict) and "risks" in extracted_risks:
                risks.extend(extracted_risks["risks"])
        except Exception:
            risks.append("Risk extraction failed — manual review recommended")

        # Determine confidence level
        if not passed or "FAIL" in critique_text:
            confidence = "low"
        elif "WARN" in critique_text:
            confidence = "medium"
        else:
            confidence = "high"

        return FinalRecommendation(
            summary=analysis[:500] + "..." if len(analysis) > 500 else analysis,
            detailed_analysis=analysis,
            risks=risks,
            action_items=["Review the detailed analysis", "Consult a licensed financial advisor before acting"],
            confidence_level=confidence,
            reasoning_trace=trace,
            critique_result=critique,
            disclaimer=(
                "This analysis is generated by an AI system and does not constitute "
                "professional financial advice. All recommendations should be reviewed "
                "with a qualified financial advisor before implementation."
            ),
        )
