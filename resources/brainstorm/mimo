```python
"""
Run the complete evaluation harness against benchmark questions.
Generates a full reasoning quality report.

Usage: python -m evaluation.run_evaluation
"""

import json
import os
import logging
from datetime import datetime

from evaluation.benchmark_questions import BENCHMARK_QUESTIONS
from evaluation.evaluator import ReasoningQualityEvaluator
from agents.orchestrator import FinRootOrchestrator

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)


def run_full_evaluation(output_dir: str = "./evaluation/results"):
    """Run evaluation on all benchmark questions."""
    os.makedirs(output_dir, exist_ok=True)

    orchestrator = FinRootOrchestrator()
    evaluator = ReasoningQualityEvaluator()

    logger.info(f"Starting evaluation with {len(BENCHMARK_QUESTIONS)} benchmark questions")

    for bq in BENCHMARK_QUESTIONS:
        logger.info(f"Evaluating {bq['id']}: {bq['domain']} ({bq['difficulty']})")

        # Run the full agent pipeline
        recommendation = orchestrator.run(bq["question"])

        # Evaluate the reasoning quality
        eval_result = evaluator.evaluate_single(
            question_id=bq["id"],
            domain=bq["domain"],
            question=bq["question"],
            expected_elements=bq["expected_elements"],
            scoring_rubric=bq["scoring_rubric"],
            agent_response=recommendation.detailed_analysis,
            critique_result=recommendation.critique_result,
        )

        logger.info(
            f"  {bq['id']}: Overall={eval_result.overall_score:.1f} "
            f"(C={eval_result.correctness_score}, R={eval_result.risk_awareness_score}, "
            f"A={eval_result.actionability_score}, E={eval_result.explainability_score})"
        )

    # Generate and save report
    report = evaluator.get_aggregate_report()
    report["generated_at"] = datetime.now().isoformat()
    report["model_used"] = orchestrator.llm.model_name if hasattr(orchestrator.llm, 'model_name') else 'unknown'

    report_path = os.path.join(output_dir, f"evaluation_report_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json")
    with open(report_path, "w") as f:
        json.dump(report, f, indent=2)

    # Print summary
    print("\n" + "=" * 60)
    print("FINROOT REASONING QUALITY EVALUATION REPORT")
    print("=" * 60)
    print(f"Questions Evaluated: {report['total_questions']}")
    print(f"Overall Average Score: {report['overall_average']:.2f} / 10")
    print(f"\nDimension Averages:")
    for dim, avg in report["dimension_averages"].items():
        print(f"  {dim}: {avg:.2f} / 10")
    print(f"\nBy Domain:")
    for domain, data in report["by_domain"].items():
        print(f"  {domain}: {data['average_score']:.2f} ({data['count']} questions)")
    print(f"\nFull report saved to: {report_path}")
    print("=" * 60)


if __name__ == "__main__":
    run_full_evaluation()
