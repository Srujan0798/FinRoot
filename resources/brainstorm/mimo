import functools
import time
import logging
from typing import Optional

import yfinance as yf
from langchain_core.tools import tool

logger = logging.getLogger(__name__)

# Simple in-memory cache with TTL
_cache: dict[str, tuple[float, any]] = {}
CACHE_TTL = 300  # seconds


def _cached(key: str, ttl: int = CACHE_TTL):
    """Decorator-style cache lookup."""
    if key in _cache:
        ts, val = _cache[key]
        if time.time() - ts < ttl:
            return val
    return None


def _set_cache(key: str, value):
    _cache[key] = (time.time(), value)


@tool
def get_stock_price(symbol: str) -> str:
    """Get the current price and basic info for a stock symbol.
    
    Args:
        symbol: Stock ticker symbol (e.g., 'AAPL', 'MSFT', 'GOOGL')
    
    Returns:
        Current price, day range, 52-week range, volume, and market cap.
    """
    cache_key = f"price_{symbol}"
    cached = _cached(cache_key, ttl=60)
    if cached:
        return cached

    try:
        ticker = yf.Ticker(symbol)
        info = ticker.info

        if not info or "currentPrice" not in info:
            return f"Could not retrieve price data for {symbol}. The symbol may be invalid or data unavailable."

        result = (
            f"Stock: {symbol}\n"
            f"Current Price: ${info.get('currentPrice', 'N/A')}\n"
            f"Day Range: ${info.get('dayLow', 'N/A')} - ${info.get('dayHigh', 'N/A')}\n"
            f"52-Week Range: ${info.get('fiftyTwoWeekLow', 'N/A')} - ${info.get('fiftyTwoWeekHigh', 'N/A')}\n"
            f"Volume: {info.get('volume', 'N/A'):,}\n"
            f"Market Cap: ${info.get('marketCap', 'N/A'):,}\n"
            f"P/E Ratio: {info.get('trailingPE', 'N/A')}\n"
            f"Dividend Yield: {info.get('dividendYield', 'N/A')}\n"
            f"Data retrieved at: {time.strftime('%Y-%m-%d %H:%M:%S UTC', time.gmtime())}"
        )
        _set_cache(cache_key, result)
        return result

    except Exception as e:
        logger.error(f"Error fetching price for {symbol}: {e}")
        return f"Error retrieving data for {symbol}: {str(e)}"


@tool
def get_historical_data(symbol: str, period: str = "1y") -> str:
    """Get historical price data for a stock.
    
    Args:
        symbol: Stock ticker symbol
        period: Time period - '1mo', '3mo', '6mo', '1y', '2y', '5y', '10y', 'max'
    
    Returns:
        Summary statistics of historical price data including returns and volatility.
    """
    cache_key = f"hist_{symbol}_{period}"
    cached = _cached(cache_key)
    if cached:
        return cached

    try:
        ticker = yf.Ticker(symbol)
        hist = ticker.history(period=period)

        if hist.empty:
            return f"No historical data available for {symbol} for period {period}."

        import numpy as np

        daily_returns = hist["Close"].pct_change().dropna()

        result = (
            f"Historical Data Summary for {symbol} ({period}):\n"
            f"Start Price: ${hist['Close'].iloc[0]:.2f}\n"
            f"End Price: ${hist['Close'].iloc[-1]:.2f}\n"
            f"Total Return: {((hist['Close'].iloc[-1] / hist['Close'].iloc[0]) - 1) * 100:.2f}%\n"
            f"Annualized Volatility: {daily_returns.std() * np.sqrt(252) * 100:.2f}%\n"
            f"Max Price: ${hist['Close'].max():.2f}\n"
            f"Min Price: ${hist['Close'].min():.2f}\n"
            f"Average Daily Volume: {hist['Volume'].mean():,.0f}\n"
