"""Audit Trail — append-only logging of all reasoning steps for full transparency."""

import json
import sqlite3
import uuid
import time
import os
from typing import Any

DB_PATH = os.path.join(os.path.dirname(__file__), "..", "data", "audit_trail.db")


class AuditTrail:
    """Append-only audit trail stored in SQLite for full reasoning transparency."""

    def __init__(self, db_path: str = DB_PATH):
        self.db_path = db_path
        os.makedirs(os.path.dirname(db_path), exist_ok=True)
        self._init_db()

    def _init_db(self):
        """Initialize the audit trail database."""
        with sqlite3.connect(self.db_path) as conn:
            conn.execute("""
                CREATE TABLE IF NOT EXISTS sessions (
                    session_id TEXT PRIMARY KEY,
                    user_query TEXT NOT NULL,
                    created_at TEXT NOT NULL
                )
            """)
            conn.execute("""
                CREATE TABLE IF NOT EXISTS reasoning_steps (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    session_id TEXT NOT NULL,
                    step_name TEXT NOT NULL,
                    step_data TEXT NOT NULL,
                    timestamp TEXT NOT NULL,
                    FOREIGN KEY (session_id) REFERENCES sessions(session_id)
                )
            """)
            conn.commit()

    def new_session(self, user_query: str) -> str:
        """Start a new audit session and return its ID."""
        session_id = str(uuid.uuid4())[:8]
        with sqlite3.connect(self.db_path) as conn:
            conn.execute(
                "INSERT INTO sessions (session_id, user_query, created_at) VALUES (?, ?, ?)",
                (session_id, user_query, time.strftime("%Y-%m-%d %H:%M:%S")),
            )
            conn.commit()
        return session_id

    def log_step(self, session_id: str, step_name: str, step_data: Any):
        """Log a reasoning step (append-only)."""
        with sqlite3.connect(self.db_path) as conn:
            conn.execute(
                "INSERT INTO reasoning_steps (session_id, step_name, step_data, timestamp) VALUES (?, ?, ?, ?)",
                (
                    session_id,
                    step_name,
                    json.dumps(step_data, default=str),
                    time.strftime("%Y-%m-%d %H:%M:%S"),
                ),
            )
            conn.commit()

    def get_session_trace(self, session_id: str) -> list[dict]:
        """Retrieve the full reasoning trace for a session."""
        with sqlite3.connect(self.db_path) as conn:
            conn.row_factory = sqlite3.Row
            rows = conn.execute(
                "SELECT step_name, step_data, timestamp FROM reasoning_steps WHERE session_id = ? ORDER BY id",
                (session_id,),
            ).fetchall()
            return [dict(row) for row in rows]

    def get_all_sessions(self) -> list[dict]:
        """List all audit sessions."""
        with sqlite3.connect(self.db_path) as conn:
            conn.row_factory = sqlite3.Row
            rows = conn.execute("SELECT * FROM sessions ORDER BY created_at DESC").fetchall()
            return [dict(row) for row in rows]
