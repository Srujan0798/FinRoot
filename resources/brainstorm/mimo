class UserProfileMemory:
    """Persistent, structured user financial profile."""

    def __init__(self, profile_path: str = PROFILE_PATH):
        self.profile_path = profile_path
        os.makedirs(os.path.dirname(profile_path), exist_ok=True)
        self._ensure_profile()

    def _ensure_profile(self):
        if not os.path.exists(self.profile_path):
            self.save_profile(DEFAULT_PROFILE)

    def get_profile(self) -> dict:
        """Load the current user profile."""
        try:
            with open(self.profile_path, "r") as f:
                return json.load(f)
        except (json.JSONDecodeError, FileNotFoundError):
            return DEFAULT_PROFILE.copy()

    def save_profile(self, profile: dict):
        """Save the user profile."""
        with open(self.profile_path, "w") as f:
            json.dump(profile, f, indent=2)

    def update_field(self, field_path: str, value):
        """Update a specific field in the profile using dot notation."""
        profile = self.get_profile()
        keys = field_path.split(".")
        current = profile
        for key in keys[:-1]:
            current = current.setdefault(key, {})
        current[keys[-1]] = value
        self.save_profile(profile)

    def update_from_conversation(self, extracted_info: dict):
        """Update profile based on information extracted from conversation."""
        profile = self.get_profile()
        for key, value in extracted_info.items():
            if key in profile and value is not None:
                profile[key] = value
        profile["interaction_count"] = profile.get("interaction_count", 0) + 1
        self.save_profile(profile)
