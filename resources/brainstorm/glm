#### **`src/agents/tools.py` (Custom Tools)**
```python
from langchain.tools import StructuredTool
from pydantic import BaseModel, Field
import yfinance as yf

class StockInput(BaseModel):
    ticker: str = Field(description="Ticker symbol for the stock (e.g., AAPL)")

def get_stock_fundamentals(ticker: str) -> str:
    """Fetches P/E, Market Cap, and Sector info."""
    try:
        stock = yf.Ticker(ticker)
        info = stock.info
        return (f"Ticker: {ticker}\n"
                f"Sector: {info.get('sector', 'N/A')}\n"
                f"Industry: {info.get('industry', 'N/A')}\n"
                f"P/E Ratio: {info.get('trailingPE', 'N/A')}\n"
                f"Market Cap: {info.get('marketCap', 'N/A')}")
    except Exception as e:
        return f"Error fetching data for {ticker}: {str(e)}"

fundamental_tool = StructuredTool.from_function(
    func=get_stock_fundamentals,
    name="FundamentalAnalysis",
    description="Useful for getting P/E ratio, sector, and market cap of a stock.",
    args_schema=StockInput
)
```

