from interface.core import answer

# Check what specific risk query produces
for q in ['What is my risk tolerance?', 'Analyze my portfolio risk', 'Stress test my portfolio']:
    state = answer(q)
    rec = state.candidate or state.final
    print(f'Query: {q}')
    print(f'  Intent: {state.intent}')
    print(f'  Verdict verifier: {state.verifier_verdict is not None}')
    print(f'  Rec texts: {rec.summary[:150] if rec else \"None\"}')
    print(f'  Risk keywords in text: {\"risk\" in (rec.summary + rec.analysis).lower() if rec else \"N/A\"}')
    print()

# Check what international-ish queries produce in tool outputs
state = answer('What is the exchange rate between USD and INR?')
rec = state.candidate or state.final
print('=== EXCHANGE RATE ===')
tool_text = ' '.join(str(o) for o in state.tool_outputs).lower()
print('Has currency:', 'currency' in tool_text)
print('Has exchange:', 'exchange' in tool_text)
print('Has usd:', 'usd' in tool_text)
print('Has inr:', 'inr' in tool_text)

state = answer('How do I handle taxes on US stocks?')
rec = state.candidate or state.final
print()
print('=== US TAX ===')
