  "streamlit>=1.36",
  "yfinance>=0.2.40",
  "requests>=2.32",
]

[project.optional-dependencies]
vector = ["chromadb>=0.5"]
groq = ["groq>=0.9"]
openai = ["openai>=1.40"]
sentiment = ["transformers>=4.42", "torch>=2.3"]
dev = ["pytest>=8.2", "pytest-cov>=5", "ruff>=0.5"]

[project.scripts]
finroot = "src.interface.cli.main:app"

[tool.setuptools.packages.find]
