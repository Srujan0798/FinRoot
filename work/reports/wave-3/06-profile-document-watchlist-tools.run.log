description = "Sovereign, reasoning-first, auditable AI financial agent (LangChain + LangGraph)"
readme = "README.md"
requires-python = ">=3.11"
license = { file = "LICENSE" }
authors = [{ name = "Srujan" }]
dependencies = [
  "langchain>=0.3,<0.4",
