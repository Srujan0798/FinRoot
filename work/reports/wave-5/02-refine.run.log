from finroot.reasoning.critic import SelfCritic
from finroot.reasoning.refine import RefinementLoop
from finroot.schemas.enums import ConfidenceLevel
from finroot.schemas.recommendation import Citation, Recommendation
from finroot.schemas.state import AgentState
from datetime import UTC, datetime

UTC_NOW = datetime(2026, 6, 19, 12, 0, 0, tzinfo=UTC)
c = Citation(source='yfinance', detail='market data', value='150', retrieved_at=UTC_NOW)
rec = Recommendation(
    summary='Diversified portfolio recommendation',
    analysis='Stocks are good.',
    risks=[],
    actions=['Buy stocks'],
    citations=[c],
    confidence=ConfidenceLevel.MEDIUM,
)
state = AgentState(query='x', candidate=rec, tool_outputs=[{'tool': 'market_data', 'data': '30'}])
critic = SelfCritic()
loop = RefinementLoop()

# Run one iteration manually
verdict = critic.evaluate(state)
print(f'=== Iteration 1 ===')
print(f'Overall: {verdict.overall}, Passed: {verdict.passed}')
print(f'must_fix: {verdict.must_fix}')

# Revise
loop._revise(state, verdict)
print(f'\nAfter revision:')
print(f'  analysis: {state.candidate.analysis!r}')
print(f'  risks: {state.candidate.risks}')
print(f'  summary: {state.candidate.summary!r}')

# Re-score
verdict2 = critic.evaluate(state)
print(f'\n=== Iteration 2 ===')
print(f'Overall: {verdict2.overall}, Passed: {verdict2.passed}')
for s in verdict2.scores:
    print(f'  {s.axis}: {s.score} - {s.issues}')
print(f'must_fix: {verdict2.must_fix}')
