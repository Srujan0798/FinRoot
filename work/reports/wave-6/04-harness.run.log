# Quick sanity: test that running finroot with interface.core.answer + grade_code works
import sys
sys.path.insert(0, '.')
from interface.core import answer
from evals.graders import grade_code
import json

tasks = json.load(open('data/gold/frb_questions.json'))[:5]
for t in tasks:
    state = answer(t['query'], mock=True)
    # promote candidate → final
    if state.final is None and state.candidate is not None:
        state.final = state.candidate
    r = grade_code(t, state)
    print(f\"{t['id']:8s} score={r.score:.3f} passed={r.passed}\")
