import sys
sys.path.insert(0, '.')
from finroot.evaluation.baselines import NaiveRAGBaseline, SingleAgentBaseline
from evals.graders import grade_code
import json

tasks = json.load(open('data/gold/frb_questions.json'))[:5]
for b_name, baseline in [('RAG', NaiveRAGBaseline()), ('SingleAgent', SingleAgentBaseline())]:
    scores = []
    for t in tasks:
        state = baseline.answer(t['query'])
        r = grade_code(t, state)
        scores.append(r.score)
    print(f'{b_name}: mean={sum(scores)/len(scores):.3f}, scores={[round(s,2) for s in scores]}')
