# FinRoot environment — copy to .env. ALL optional: Mock + Ollama run with zero keys (sovereign).
# Never commit a real .env (FM-07). Prefix is FINROOT_.

# --- LLM provider: mock | ollama | groq | openai  (default: mock) ---
FINROOT_LLM_PROVIDER=mock

# --- Ollama (local sovereign mode) ---
FINROOT_OLLAMA_BASE_URL=http://localhost:11434
FINROOT_OLLAMA_MODEL=llama3.1:8b

# --- cloud providers (optional accelerators; leave blank to stay sovereign) ---
FINROOT_GROQ_API_KEY=
FINROOT_OPENAI_API_KEY=

# --- optional data/news providers (yfinance is keyless and default) ---
FINROOT_ALPHAVANTAGE_API_KEY=
FINROOT_NEWSAPI_KEY=
TAVILY_API_KEY=

# --- storage paths ---
FINROOT_CHROMA_DIR=data/chroma
FINROOT_AUDIT_PATH=logs/audit.jsonl
